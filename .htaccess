Options -Indexes
Options -MultiViews

RewriteEngine On
RewriteBase /

# Block access to sensitive files
RewriteRule ^config\.php$ - [F,L]

# Static files - serve directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route /hizmetler/slug
RewriteRule ^hizmetler/([^/]+)/?$ /service.php?slug=$1 [QSA,L]
# Route /hizmetler
RewriteRule ^hizmetler/?$ /services.php [QSA,L]
# Route /blog/slug
RewriteRule ^blog/([^/]+)/?$ /post.php?slug=$1 [QSA,L]
# Route /blog
RewriteRule ^blog/?$ /blog.php [QSA,L]
# Route pages
RewriteRule ^hakkimizda/?$ /about.php [QSA,L]
RewriteRule ^iletisim/?$ /contact.php [QSA,L]
# Admin routes
RewriteRule ^admin/?$ /admin/index.php [QSA,L]
RewriteRule ^admin/login/?$ /admin/login.php [QSA,L]
RewriteRule ^admin/logout/?$ /admin/logout.php [QSA,L]

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options nosniff
  Header always set X-Frame-Options SAMEORIGIN
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>
